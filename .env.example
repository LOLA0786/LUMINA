# ── LUMINA Environment Configuration ──────────────────────────────
# Copy this to .env and fill in your values
# NEVER commit .env to git

# App
APP_NAME="LUMINA Financial OS"
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Financial rules
EMERGENCY_FUND_MONTHS=6
LTV_CAP_PCT=0.80
MAX_FOIR_PCT=0.50
SINGLE_ACTION_LIMIT_INR=500000
MIN_AGENT_CONFIDENCE=0.60

# Tax FY24-25
LTCG_EXEMPTION_INR=125000
MAX_80C_INR=150000

# Database
DATABASE_URL=sqlite:///lumina.db

# API
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET_KEY=change-this-in-production
JWT_EXPIRE_MINUTES=60

# Governance
GOVERNANCE_ENABLED=true
MERKLE_LOG_ENABLED=true
AUDIT_RETENTION_DAYS=2555

# External feeds (leave blank in dev)
MARKET_FEED_URL=
RBI_FEED_URL=
BANK_WEBHOOK_SECRET=
